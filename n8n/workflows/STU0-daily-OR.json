{
  "name": "BDI · STU0 Daily OR submission",
  "_meta": {
    "owner": "A6 Fabric (deploy) · STU0 (spec)",
    "authority": "D-STU-082 cron schedules + PI v4.1 sekcja 12 Tier 1",
    "purpose": "Daily 11:00 PL · STU0 daily OR consolidation · queries cp_messages za poprzedni working day · summarizes · posts do #ws-bdi-studio + emits envelope",
    "schedule": "0 11 * * 1-5 (Europe/Warsaw · M-F robocze)",
    "envelope_emits": "control_plane.cp_messages · message_type=OR_SUBMISSION · actor=agent.specialist.STU0",
    "consumers": ["#ws-bdi-studio", "agent.or_archive", "KR digest"],
    "sprint": "2 day-2 spec · sprint-3 D-X actual n8n deploy"
  },
  "nodes": [
    {
      "name": "Cron 11:00 PL M-F",
      "type": "n8n-nodes-base.cron",
      "position": [240, 300],
      "parameters": {
        "triggerTimes": {
          "item": [
            { "mode": "everyDay", "hour": 11, "minute": 0, "weekday": "monday,tuesday,wednesday,thursday,friday" }
          ]
        },
        "timezone": "Europe/Warsaw"
      }
    },
    {
      "name": "Query F10/F11 yesterday",
      "type": "n8n-nodes-base.supabase",
      "position": [440, 300],
      "parameters": {
        "operation": "rpc",
        "rpcName": "stu0_daily_or_aggregate",
        "_rpc_spec": "SELECT message_type, count(*) AS cnt, jsonb_agg(payload->>'employee_id') AS employees FROM control_plane.cp_messages WHERE created_at >= (now() - interval '24 hours') AND message_type IN ('F10_PRIORITIES','F11_CLOSURE') GROUP BY message_type",
        "credentials": "supabase-prod-service-role"
      }
    },
    {
      "name": "Call Anthropic API · summarize",
      "type": "n8n-nodes-base.httpRequest",
      "position": [640, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "headerAuth",
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $credentials['prod-console-anthropic-api-key'] }}" },
            { "name": "anthropic-version", "value": "2023-06-01" }
          ]
        },
        "jsonBody": true,
        "bodyParametersJson": "={\"model\":\"claude-sonnet-4-6\",\"max_tokens\":1024,\"messages\":[{\"role\":\"user\",\"content\":\"Summarize STU0 daily OR per PI v4.1 sekcja 6 Pattern A. BDI Studio status post-{{ $now.minus({days:1}).toFormat('yyyy-MM-dd') }} from cp_messages: F10 posts={{ $json['F10_PRIORITIES']?.cnt || 0 }}, F11 posts={{ $json['F11_CLOSURE']?.cnt || 0 }}. BLUF first sentence, R14, R21. Output:\\n```yaml\\nor_summary: ...\\nbluf: ...\\nblockers: ...\\nnext: ...\\n```\"}]}"
      }
    },
    {
      "name": "Format Pattern A markdown",
      "type": "n8n-nodes-base.function",
      "position": [840, 300],
      "parameters": {
        "functionCode": "const summary = $input.first().json.content[0].text;\nconst yyyy_mm_dd = new Date().toISOString().split('T')[0];\nreturn [{\n  json: {\n    or_markdown: `# STU0 Daily OR · ${yyyy_mm_dd}\\n\\n${summary}\\n\\n---\\nGenerated by n8n.workflow.STU0-daily-OR · 11:00 PL`,\n    or_yaml: summary\n  }\n}];"
      }
    },
    {
      "name": "Post Slack #ws-bdi-studio",
      "type": "n8n-nodes-base.slack",
      "position": [1040, 200],
      "parameters": {
        "channel": "#ws-bdi-studio",
        "text": "={{ $json.or_markdown }}",
        "credentials": "slack-bdi-bot"
      }
    },
    {
      "name": "Emit OR_SUBMISSION envelope",
      "type": "n8n-nodes-base.supabase",
      "position": [1040, 400],
      "parameters": {
        "operation": "insert",
        "tableId": "control_plane.cp_messages",
        "fieldsUI": {
          "fields": [
            { "name": "run_id", "value": "={{ $execution.id }}" },
            { "name": "correlation_id", "value": "={{ $execution.id }}" },
            { "name": "source_workspace", "value": "BDI-STUDIO" },
            { "name": "target_workspace", "value": "BDI-STUDIO" },
            { "name": "domain", "value": "BDI-GOV" },
            { "name": "actor_type", "value": "CCA" },
            { "name": "actor_id", "value": "agent.specialist.STU0" },
            { "name": "sensitivity_level", "value": "L1_INTERNAL" },
            { "name": "message_type", "value": "OR_SUBMISSION" },
            { "name": "payload", "value": "={\"agent_id\":\"agent.specialist.STU0\",\"content\":$json.or_markdown,\"pattern\":\"A\",\"summary\":$json.or_yaml}" }
          ]
        },
        "credentials": "supabase-prod-service-role"
      }
    }
  ],
  "connections": {
    "Cron 11:00 PL M-F": { "main": [[{ "node": "Query F10/F11 yesterday", "type": "main", "index": 0 }]] },
    "Query F10/F11 yesterday": { "main": [[{ "node": "Call Anthropic API · summarize", "type": "main", "index": 0 }]] },
    "Call Anthropic API · summarize": { "main": [[{ "node": "Format Pattern A markdown", "type": "main", "index": 0 }]] },
    "Format Pattern A markdown": { "main": [[
      { "node": "Post Slack #ws-bdi-studio", "type": "main", "index": 0 },
      { "node": "Emit OR_SUBMISSION envelope", "type": "main", "index": 0 }
    ]] }
  },
  "settings": { "executionOrder": "v1", "errorWorkflow": "wf-error-handler-cp-dlq" },
  "active": false,
  "_deploy_notes": "Set active:true after F10/F11 LIVE · STU0 OR aggregates yesterday data · 11:00 PL window gives F10 morning posts time to land."
}
