{
  "name": "BDI · Friday Weekly Review",
  "_meta": {
    "owner": "A6 Fabric (deploy) · STU0 (spec)",
    "authority": "D-OPS-15 Weekly Review cadence + PI v4.1 sekcja 12 Tier 2",
    "purpose": "Friday 14:00 PL · Aggregate week's cp_messages → KR digest · 5-section briefing (this week / blockers / decisions / next week / KPIs)",
    "schedule": "0 14 * * 5 (Europe/Warsaw · Pt)",
    "envelope_emits": "control_plane.cp_messages · message_type=WEEKLY_REVIEW",
    "consumers": ["#bdi-kr-digest", "agent.weekly_review_archive", "Drive append-only WEEKLY-REVIEW/"],
    "sprint": "2 day-2 spec · sprint-3 D-X actual n8n deploy"
  },
  "nodes": [
    {
      "name": "Cron Friday 14:00 PL",
      "type": "n8n-nodes-base.cron",
      "position": [240, 300],
      "parameters": {
        "triggerTimes": { "item": [{ "mode": "everyDay", "hour": 14, "minute": 0, "weekday": "friday" }] },
        "timezone": "Europe/Warsaw"
      }
    },
    {
      "name": "Aggregate week's cp_messages",
      "type": "n8n-nodes-base.supabase",
      "position": [440, 300],
      "parameters": {
        "operation": "rpc",
        "rpcName": "stu0_weekly_review_aggregate",
        "_rpc_spec": "SELECT message_type, count(*), array_agg(DISTINCT actor_id) AS contributors, array_agg(DISTINCT source_workspace) AS workspaces FROM control_plane.cp_messages WHERE created_at >= (now() - interval '7 days') GROUP BY message_type ORDER BY count DESC",
        "credentials": "supabase-prod-service-role"
      }
    },
    {
      "name": "Query DECISION_DELTA · week",
      "type": "n8n-nodes-base.supabase",
      "position": [440, 450],
      "parameters": {
        "operation": "select",
        "tableId": "control_plane.cp_messages",
        "filterUI": {
          "filter": [
            { "column": "message_type", "value": "DECISION_DELTA" },
            { "column": "created_at", "value": ">={{ $now.minus({days:7}).toISO() }}" }
          ]
        },
        "credentials": "supabase-prod-service-role"
      }
    },
    {
      "name": "Call Anthropic API · weekly summary",
      "type": "n8n-nodes-base.httpRequest",
      "position": [640, 350],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "headerAuth",
        "headerParameters": { "parameters": [
          { "name": "x-api-key", "value": "={{ $credentials['prod-console-anthropic-api-key'] }}" },
          { "name": "anthropic-version", "value": "2023-06-01" }
        ] },
        "jsonBody": true,
        "bodyParametersJson": "={\"model\":\"claude-sonnet-4-6\",\"max_tokens\":2048,\"messages\":[{\"role\":\"user\",\"content\":\"Generate BDI Friday Weekly Review per D-OPS-15 (append-only WEEKLY-REVIEW). Input: cp_messages aggregate {{ JSON.stringify($node['Aggregate week\\'s cp_messages'].json) }} · decisions {{ JSON.stringify($node['Query DECISION_DELTA · week'].json) }}. Output Markdown 5 sections: \\n\\n# Weekly Review · {{ $now.toFormat('yyyy-MM-dd') }}\\n## 1. BLUF (this week)\\n## 2. Blockers · current\\n## 3. Decisions appended (count + titles)\\n## 4. Next week · plan\\n## 5. KPIs week-over-week (jeśli data dostępna)\\n\\nR14 BLUF · R22 full paths · Polish language.\"}]}"
      }
    },
    {
      "name": "Format + Post Slack",
      "type": "n8n-nodes-base.function",
      "position": [840, 350],
      "parameters": {
        "functionCode": "const summary = $input.first().json.content[0].text;\nconst yyyy_mm_dd = new Date().toISOString().split('T')[0];\nreturn [{ json: { weekly_md: summary, yyyy_mm_dd } }];"
      }
    },
    {
      "name": "Post Slack #bdi-kr-digest",
      "type": "n8n-nodes-base.slack",
      "position": [1040, 250],
      "parameters": {
        "channel": "#bdi-kr-digest",
        "text": "={{ $json.weekly_md }}",
        "credentials": "slack-bdi-bot"
      }
    },
    {
      "name": "Emit WEEKLY_REVIEW envelope",
      "type": "n8n-nodes-base.supabase",
      "position": [1040, 450],
      "parameters": {
        "operation": "insert",
        "tableId": "control_plane.cp_messages",
        "fieldsUI": {
          "fields": [
            { "name": "run_id", "value": "={{ $execution.id }}" },
            { "name": "correlation_id", "value": "={{ $execution.id }}" },
            { "name": "source_workspace", "value": "BDI-STUDIO" },
            { "name": "target_workspace", "value": "BDI-ALL" },
            { "name": "domain", "value": "BDI-GOV" },
            { "name": "actor_type", "value": "N8N" },
            { "name": "actor_id", "value": "n8n.workflow.friday-weekly-review" },
            { "name": "sensitivity_level", "value": "L1_INTERNAL" },
            { "name": "message_type", "value": "WEEKLY_REVIEW" },
            { "name": "payload", "value": "={\"week_ending\": $json.yyyy_mm_dd, \"content\": $json.weekly_md}" }
          ]
        },
        "credentials": "supabase-prod-service-role"
      }
    },
    {
      "name": "Append do Drive WEEKLY-REVIEW",
      "type": "n8n-nodes-base.googleDrive",
      "position": [1240, 350],
      "parameters": {
        "operation": "create",
        "name": "={{ $json.yyyy_mm_dd }}_review.md",
        "parents": ["WEEKLY-REVIEW-FOLDER-ID-TBD"],
        "content": "={{ $json.weekly_md }}",
        "mimeType": "text/markdown",
        "credentials": "google-drive-bdi-service"
      }
    }
  ],
  "connections": {
    "Cron Friday 14:00 PL": { "main": [[
      { "node": "Aggregate week's cp_messages", "type": "main", "index": 0 },
      { "node": "Query DECISION_DELTA · week", "type": "main", "index": 0 }
    ]] },
    "Aggregate week's cp_messages": { "main": [[{ "node": "Call Anthropic API · weekly summary", "type": "main", "index": 0 }]] },
    "Query DECISION_DELTA · week": { "main": [[{ "node": "Call Anthropic API · weekly summary", "type": "main", "index": 1 }]] },
    "Call Anthropic API · weekly summary": { "main": [[{ "node": "Format + Post Slack", "type": "main", "index": 0 }]] },
    "Format + Post Slack": { "main": [[
      { "node": "Post Slack #bdi-kr-digest", "type": "main", "index": 0 },
      { "node": "Emit WEEKLY_REVIEW envelope", "type": "main", "index": 0 },
      { "node": "Append do Drive WEEKLY-REVIEW", "type": "main", "index": 0 }
    ]] }
  },
  "settings": { "executionOrder": "v1", "errorWorkflow": "wf-error-handler-cp-dlq" },
  "active": false,
  "_deploy_notes": "Set WEEKLY-REVIEW-FOLDER-ID-TBD to actual Drive folder ID (per D-OPS-15) post A6 confirms · activate."
}
